{
  "name": "ironclaw",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @ironclaw/shared db:generate",
    "db:migrate": "pnpm --filter @ironclaw/shared db:migrate",
    "start": "pnpm --filter @ironclaw/runtime start",
    "start:gateway": "pnpm --filter @ironclaw/gateway start",
    "start:runtime": "pnpm --filter @ironclaw/runtime worker",
    "start:web": "pnpm --filter @ironclaw/web dev",
    "start:all": "bash scripts/start-all.sh",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @ironclaw/shared test:integration",
    "update-injection-patterns": "tsx scripts/update-injection-patterns.ts"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0"
  }
}
